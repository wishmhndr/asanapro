generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native"]
  engineType    = "library"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Agency {
  id        String   @id @default(uuid())
  name      String
  address   String?
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  properties Property[]
  expenses   AgencyExpense[]
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String
  name        String
  phoneNumber String?
  role        UserRole @default(MARKETING)

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  // Relations
  clients Client[]   // Marketing: klien milik sendiri
  deals   Deal[]     // Deal yang ditutup oleh Marketing ini

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  ADMIN
  MARKETING
}

model Property {
  id           String       @id @default(uuid())
  title        String
  description  String
  price        Float
  location     String
  propertyType PropertyType @default(HOUSE)
  status       PropertyStatus @default(AVAILABLE)

  landArea     Float?
  buildingArea Float?
  yearBuilt    Int?
  features     String?
  legality     String?
  certificate  String?

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  images PropertyImage[]
  deals  Deal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PropertyType {
  HOUSE
  APARTMENT
  LAND
  COMMERCIAL
  VILLA
}

enum PropertyStatus {
  AVAILABLE
  UNDER_NEGOTIATION
  SOLD
  RENTED
}

model PropertyImage {
  id         String   @id @default(uuid())
  url        String
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model Client {
  id                 String       @id @default(uuid())
  name               String
  email              String?
  whatsapp           String
  status             ClientStatus @default(NEW)
  notes              String?
  minBudget          Float?
  maxBudget          Float?
  propertyType       String?
  locationPreference String?

  marketingId String
  marketing   User   @relation(fields: [marketingId], references: [id], onDelete: Cascade)

  followUps FollowUp[]
  deals     Deal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ClientStatus {
  NEW
  PROSPECT
  HOT
  DEAL
  LOST
}

model FollowUp {
  id             String      @id @default(uuid())
  content        String
  type           FollowUpType @default(WHATSAPP)
  followUpDate   DateTime?

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

enum FollowUpType {
  CALL
  WHATSAPP
  VISIT
  MEETING
  EMAIL
}

model Deal {
  id               String     @id @default(uuid())
  dealType         DealType
  dealPrice        Float
  status           DealStatus @default(IN_PROGRESS)
  paymentStatus    DealPaymentStatus @default(PENDING)
  totalInstallments Int       @default(1)
  paymentStartDate DateTime?
  notes            String?

  // Khusus sewa
  rentStartDate DateTime?
  rentEndDate   DateTime?

  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  marketingId String
  marketing   User   @relation(fields: [marketingId], references: [id])

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum DealType {
  SALE
  RENT
}

enum DealStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum DealPaymentStatus {
  PENDING
  IN_PROGRESS
  OVERDUE
  COMPLETED
}

model Payment {
  id                String        @id @default(uuid())
  amount            Float
  paymentType       PaymentType
  paymentMethod     PaymentMethod @default(TRANSFER)
  installmentNumber Int?
  paidAt            DateTime
  notes             String?

  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

enum PaymentType {
  DOWN_PAYMENT
  INSTALLMENT
  FULL_PAYMENT
}

enum PaymentMethod {
  CASH
  TRANSFER
  KPR
  KPA
}

model AgencyExpense {
  id          String          @id @default(uuid())
  amount      Float
  description String
  category    ExpenseCategory @default(OPERATIONAL)
  expenseDate DateTime

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

enum ExpenseCategory {
  OPERATIONAL
  MARKETING_FEE
  SALARY
  OTHER
}
